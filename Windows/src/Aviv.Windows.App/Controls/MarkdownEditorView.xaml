<UserControl
    x:Class="Aviv.Windows.App.Controls.MarkdownEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Aviv.Windows.App.Controls">
    <Grid Background="#FFFBFCFD">
        <RichEditBox
            x:Name="Editor"
            AcceptsReturn="True"
            BorderThickness="0"
            Background="Transparent"
            FontFamily="Segoe UI"
            FontSize="17"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            IsSpellCheckEnabled="True"
            Padding="64,72,122,52"
            SelectionHighlightColor="#33248ACB"
            TextWrapping="Wrap"
            VerticalAlignment="Stretch"
            TextChanged="OnTextChanged"
            SelectionChanged="OnSelectionChanged" />

        <Border
            Height="54"
            VerticalAlignment="Top"
            Background="#DDFDFEFF"
            BorderBrush="#1F6B7280"
            BorderThickness="0,0,0,1">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="#FF6A7280"
                Text="{Binding DocumentTitle}" />
        </Border>

        <Border
            Width="86"
            Margin="0,58,12,40"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Background="#DDFDFEFF"
            BorderBrush="#1F6B7280"
            BorderThickness="1"
            CornerRadius="7">
            <controls:MarkdownMinimapView x:Name="Minimap" Margin="5" />
        </Border>

        <TextBlock
            Margin="0,0,18,12"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            FontSize="12"
            Foreground="#FF6A7280"
            Text="{Binding StatusText}" />

        <Popup x:Name="SourcePopup" IsLightDismissEnabled="True">
            <Border
                Background="#DDFDFEFF"
                BorderBrush="#1F6B7280"
                BorderThickness="1"
                CornerRadius="6"
                Padding="6">
                <TextBox
                    x:Name="SourceEditor"
                    MinWidth="280"
                    BorderThickness="0"
                    FontFamily="Cascadia Mono"
                    FontSize="12"
                    KeyDown="OnSourceEditorKeyDown" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
