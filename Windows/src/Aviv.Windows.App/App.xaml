<Application
    x:Class="Aviv.Windows.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="AvivBackgroundColor">#FFFBFCFD</Color>
            <Color x:Key="AvivTextColor">#FF20242A</Color>
            <Color x:Key="AvivSecondaryTextColor">#FF6A7280</Color>
            <Color x:Key="AvivSyntaxColor">#FF97A0AD</Color>
            <Color x:Key="AvivHiddenSyntaxColor">#0097A0AD</Color>
            <Color x:Key="AvivAccentColor">#FF0C74B8</Color>
            <Color x:Key="AvivSelectionColor">#33248ACB</Color>
            <Color x:Key="AvivCodeBackgroundColor">#FFF1F4F7</Color>
            <Color x:Key="AvivChromeColor">#DDFDFEFF</Color>
            <Color x:Key="AvivChromeStrokeColor">#1F6B7280</Color>

            <SolidColorBrush x:Key="AvivBackgroundBrush" Color="{StaticResource AvivBackgroundColor}" />
            <SolidColorBrush x:Key="AvivTextBrush" Color="{StaticResource AvivTextColor}" />
            <SolidColorBrush x:Key="AvivSecondaryTextBrush" Color="{StaticResource AvivSecondaryTextColor}" />
            <SolidColorBrush x:Key="AvivSyntaxBrush" Color="{StaticResource AvivSyntaxColor}" />
            <SolidColorBrush x:Key="AvivAccentBrush" Color="{StaticResource AvivAccentColor}" />
            <SolidColorBrush x:Key="AvivSelectionBrush" Color="{StaticResource AvivSelectionColor}" />
            <SolidColorBrush x:Key="AvivCodeBackgroundBrush" Color="{StaticResource AvivCodeBackgroundColor}" />
            <SolidColorBrush x:Key="AvivChromeBrush" Color="{StaticResource AvivChromeColor}" />
            <SolidColorBrush x:Key="AvivChromeStrokeBrush" Color="{StaticResource AvivChromeStrokeColor}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
