<Window
    x:Class="Aviv.Windows.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Aviv.Windows.App.Controls">
    <Grid x:Name="RootGrid" Background="{ThemeResource AvivBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0" Background="{ThemeResource AvivChromeBrush}">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="New" Command="{Binding NewDocumentCommand}" />
                <MenuFlyoutItem Text="New Tab" Command="{Binding NewTabCommand}" />
                <MenuFlyoutItem Text="Open..." Command="{Binding OpenDocumentCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Close" Command="{Binding CloseDocumentCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Save" Command="{Binding SaveDocumentCommand}" />
                <MenuFlyoutItem Text="Save As..." Command="{Binding SaveDocumentAsCommand}" />
                <MenuFlyoutItem Text="Revert to Saved" Command="{Binding RevertDocumentCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Page Setup..." Command="{Binding PageSetupCommand}" />
                <MenuFlyoutItem Text="Print..." Command="{Binding PrintDocumentCommand}" />
            </MenuBarItem>

            <MenuBarItem Title="Edit">
                <MenuFlyoutItem Text="Undo" Command="{Binding UndoCommand}" />
                <MenuFlyoutItem Text="Redo" Command="{Binding RedoCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Cut" Command="{Binding CutCommand}" />
                <MenuFlyoutItem Text="Copy" Command="{Binding CopyCommand}" />
                <MenuFlyoutItem Text="Paste" Command="{Binding PasteCommand}" />
                <MenuFlyoutItem Text="Paste and Match Style" Command="{Binding PastePlainTextCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Select All" Command="{Binding SelectAllCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Find..." Command="{Binding FindCommand}" />
                <MenuFlyoutItem Text="Find and Replace..." Command="{Binding FindAndReplaceCommand}" />
                <MenuFlyoutItem Text="Find Next" Command="{Binding FindNextCommand}" />
                <MenuFlyoutItem Text="Find Previous" Command="{Binding FindPreviousCommand}" />
            </MenuBarItem>

            <MenuBarItem Title="View">
                <MenuFlyoutItem Text="Actual Size" Command="{Binding ResetTextSizeCommand}" />
                <MenuFlyoutItem Text="Zoom In" Command="{Binding IncreaseTextSizeCommand}" />
                <MenuFlyoutItem Text="Zoom Out" Command="{Binding DecreaseTextSizeCommand}" />
            </MenuBarItem>

            <MenuBarItem Title="Format">
                <MenuFlyoutItem Text="Bold" Command="{Binding ToggleBoldCommand}" />
                <MenuFlyoutItem Text="Italic" Command="{Binding ToggleItalicCommand}" />
                <MenuFlyoutItem Text="Code" Command="{Binding ToggleCodeCommand}" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Heading 1" Command="{Binding Heading1Command}" />
                <MenuFlyoutItem Text="Heading 2" Command="{Binding Heading2Command}" />
            </MenuBarItem>

            <MenuBarItem Title="Window">
                <MenuFlyoutItem Text="Show Previous Tab" Command="{Binding ShowPreviousTabCommand}" />
                <MenuFlyoutItem Text="Show Next Tab" Command="{Binding ShowNextTabCommand}" />
                <MenuFlyoutItem Text="Move Tab to New Window" Command="{Binding MoveTabToNewWindowCommand}" />
                <MenuFlyoutItem Text="Merge All Windows" Command="{Binding MergeAllWindowsCommand}" />
            </MenuBarItem>
        </MenuBar>

        <controls:MarkdownEditorView x:Name="EditorView" Grid.Row="1" />
    </Grid>
</Window>
